+def _read_balanced_group(text: str, start: int) -> tuple[str, int] | None:
+    if start >= len(text) or text[start] != '{':
+        return None
+    depth = 0
+    for idx in range(start, len(text)):
+        char = text[idx]
+        if char == '{':
+            depth += 1
+        elif char == '}':
+            depth -= 1
+            if depth == 0:
+                return text[start + 1:idx], idx + 1
+    return None
+
+
+def _read_root_degree(text: str, start: int) -> tuple[str, int] | None:
+    idx = start
+    while idx < len(text) and text[idx].isspace():
+        idx += 1
+    if idx >= len(text):
+        return None
+    if text[idx] == '{':
+        group = _read_balanced_group(text, idx)
+        if not group:
+            return None
+        return group
+    end = idx
+    while end < len(text) and not text[end].isspace():
+        if text.startswith(r'\of', end):
+            break
+        end += 1
+    degree = text[idx:end].strip()
+    if not degree:
+        return None
+    return degree, end
+
+
+def _read_root_radicand(text: str, start: int) -> tuple[str, int] | None:
+    idx = start
+    while idx < len(text) and text[idx].isspace():
+        idx += 1
+    if idx >= len(text):
+        return None
+    if text[idx] == '{':
+        return _read_balanced_group(text, idx)
+    if text[idx] == '\\':
+        match = re.match(r'\\[A-Za-z]+', text[idx:])
+        if match:
+            return match.group(0), idx + len(match.group(0))
+    return text[idx], idx + 1
+
+
+def _normalize_tex_root_primitive(text: str) -> str:
+    formula = str(text or '')
+    pieces = []
+    cursor = 0
+    while True:
+        root_idx = formula.find(r'\root', cursor)
+        if root_idx == -1:
+            pieces.append(formula[cursor:])
+            break
+        degree = _read_root_degree(formula, root_idx + len(r'\root'))
+        if not degree:
+            pieces.append(formula[cursor:root_idx + len(r'\root')])
+            cursor = root_idx + len(r'\root')
+            continue
+        degree_text, after_degree = degree
+        idx = after_degree
+        while idx < len(formula) and formula[idx].isspace():
+            idx += 1
+        if not formula.startswith(r'\of', idx):
+            pieces.append(formula[cursor:root_idx + len(r'\root')])
+            cursor = root_idx + len(r'\root')
+            continue
+        radicand = _read_root_radicand(formula, idx + len(r'\of'))
+        if not radicand:
+            pieces.append(formula[cursor:root_idx + len(r'\root')])
+            cursor = root_idx + len(r'\root')
+            continue
+        radicand_text, after_radicand = radicand
+        pieces.append(formula[cursor:root_idx])
+        pieces.append(rf'\sqrt[{degree_text}]{{{radicand_text}}}')
+        cursor = after_radicand
+    return ''.join(pieces)
+
+
+def _downgrade_dynamic_delimiters(text: str) -> str:
+    formula = str(text or '')
+    for source, replacement in _DYNAMIC_DELIMITER_REPLACEMENTS:
+        formula = formula.replace(source, replacement)
+    return formula
+
+
+def _normalize_mathop_limits(text: str) -> str:
+    formula = str(text or '')
+    formula = _MATHOP_OPERATORNAME_LIMITS_RE.sub(r'\1', formula)
+    formula = _MATHOP_LIMITS_RE.sub(r'\1', formula)
+    return formula
+
+
+def _normalize_cdm_compatible_commands(text: str) -> str:
+    formula = str(text or '')
+    formula = _INLINE_MATH_MARKER_RE.sub(' ', formula)
+    formula = _normalize_tex_root_primitive(formula)
+    formula = formula.replace(r'\overrightarrow', r'\vec')
+    formula = _normalize_mathop_limits(formula)
+    formula = _strip_unmatched_leading_left_bar(formula)
+    formula = _downgrade_dynamic_delimiters(formula)
+    return formula.strip()
+
