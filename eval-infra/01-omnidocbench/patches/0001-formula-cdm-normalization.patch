+from src.core.preprocess.formula_cdm import build_matrix_cdm_variants, sanitize_formula_for_cdm
+
+
+def test_build_cdm_variant_removes_unmatched_leading_left_bar():
+    gt = r"\sum_{n=0}^{\infty} f(n) \frac{t^n}{n!} &= \int_{0}^{1} \exp(xt) dx"
+    pred = r"\left|\sum_{n=0}^{\infty}f(n)\frac{t^{n}}{n!}&=\int_{0}^{1}\exp(xt)dx"
+
+    gt_cdm, pred_cdm_alt = build_matrix_cdm_variants(gt, pred)
+
+    assert gt_cdm == gt
+    assert pred_cdm_alt.startswith(r"\sum_{n=0}^{\infty}")
+    assert r"\left|" not in pred_cdm_alt
+
+
+def test_build_cdm_variant_removes_array_cell_leading_left_bar():
+    gt = r"H_{n} = \sum_{m=0}^{k} \frac{1}{5^{m}} I_{\lfloor n/5^{m} \rfloor},"
+    pred = (
+        r"\begin{array}{r}{\left|H_{n}=\displaystyle\sum_{m=0}^{k}"
+        r"\frac{1}{5^{m}}I_{\left\lfloor n/5^{m}\right\rfloor},}\end{array}"
+    )
+
+    _, pred_cdm_alt = build_matrix_cdm_variants(gt, pred)
+
+    assert pred_cdm_alt
+    assert r"{\left|H_{n}" not in pred_cdm_alt
+
+
+def test_build_cdm_variant_normalizes_overrightarrow_for_gt_and_pred():
+    gt = r"{ \overrightarrow { P Q } \times \overrightarrow { P R } = \left( { 8 , 1 0 , 6 } \right) . }"
+    pred = r"\overrightarrow{PQ}\times\overrightarrow{PR}&=\left(8,10,6\right)."
+
+    gt_cdm, pred_cdm_alt = build_matrix_cdm_variants(gt, pred)
+
+    assert r"\overrightarrow" not in gt_cdm
+    assert r"\overrightarrow" not in pred_cdm_alt
+    assert gt_cdm.count(r"\vec") == 2
+    assert pred_cdm_alt.count(r"\vec") == 2
+
+
+def test_build_cdm_variant_preserves_regular_matrix_gt():
+    gt = r"\begin{array}{cc}a&b\\c&d\end{array}"
+    pred = r"\begin{matrix}a&b\\c&d\end{matrix}"
+
+    gt_cdm, pred_cdm_alt = build_matrix_cdm_variants(gt, pred)
+
+    assert gt_cdm == gt
+    assert pred_cdm_alt == ''
+
+
+def test_sanitize_formula_fixes_empty_array_column_spec():
+    formula = r"\begin{array}{}x=1\\y=2\end{array}"
+
+    assert sanitize_formula_for_cdm(formula).startswith(r"\begin{array}{l}")
+
+
+def test_sanitize_formula_downgrades_balanced_absolute_value_delimiters():
+    formula = r"\left|x+y\right| \leq \left|x\right|+\left|y\right|"
+
+    assert sanitize_formula_for_cdm(formula) == r"|x+y| \leq |x|+|y|"
+
+
+def test_build_cdm_variant_normalizes_tex_root_primitive_for_gt():
+    gt = r"\root n \of{\mathrm{e}}-1=\frac{1}{n}"
+
+    gt_cdm, _ = build_matrix_cdm_variants(gt, gt)
+
+    assert r"\root" not in gt_cdm
+    assert r"\of" not in gt_cdm
+    assert r"\sqrt[n]{\mathrm{e}}" in gt_cdm
+
+
+def test_build_cdm_variant_downgrades_dynamic_delimiters_for_gt():
+    gt = (
+        r"\left\{\begin{array}{l}"
+        r"\mathop{\sum }\limits_{i=1}^{n}\left\|x_i\right\|"
+        r"\\ y\in\left\lbrack J\right\rbrack"
+        r"\end{array}\right."
+    )
+
+    gt_cdm, _ = build_matrix_cdm_variants(gt, gt)
+
+    assert r"\left" not in gt_cdm
+    assert r"\right" not in gt_cdm
+    assert r"\sum_{i=1}^{n}" in gt_cdm
+    assert r"\|" in gt_cdm
+    assert r"\lbrack J\rbrack" in gt_cdm
+
+
+def test_build_cdm_variant_strips_inline_math_marker_artifacts_from_pred():
+    gt = r"\begin{cases}a,&i=1\\ b,&i=2\end{cases}"
+    pred = r"\begin{cases}a,&i=1,\ $ \partial+b,&i=2\end{cases}"
+
+    _, pred_cdm_alt = build_matrix_cdm_variants(gt, pred)
+
+    assert pred_cdm_alt
+    assert "$" not in pred_cdm_alt
+    assert r"\partial" in pred_cdm_alt
+
+
