+def _strip_unmatched_leading_left_bar(text: str) -> str:
+    formula = str(text or '').strip()
+    if not formula or formula.count(r'\left|') <= formula.count(r'\right|'):
+        return formula
+
+    formula = _ARRAY_LEADING_LEFT_BAR_RE.sub(r'\1', formula)
+    formula = _ALIGNED_LEADING_LEFT_BAR_RE.sub(r'\1', formula)
+
+    prefix = ''
+    rest = formula.lstrip()
+    while rest.startswith('&') or rest.startswith('{'):
+        prefix += rest[0]
+        rest = rest[1:].lstrip()
+    if rest.startswith(r'\left|'):
+        rest = rest[len(r'\left|'):].lstrip()
+        formula = prefix + rest
+        if formula.endswith('}') and formula.count('{') < formula.count('}'):
+            formula = formula[:-1].rstrip()
+    return formula.strip()
+
+
+def _normalize_cdm_compatible_commands(text: str) -> str:
+    formula = str(text or '')
+    formula = formula.replace(r'\overrightarrow', r'\vec')
+    formula = _strip_unmatched_leading_left_bar(formula)
+    return formula.strip()
